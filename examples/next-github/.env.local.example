# Copy this file to .env.local and fill in the values from your own GitHub
# App — see README.md for step-by-step setup instructions. Every deployer
# registers their own App (cimisy never runs a shared one); see the plan's
# note on why.

# "owner/repo" of the repository your content lives in.
CIMISY_GITHUB_REPO=your-org/your-repo
CIMISY_GITHUB_BRANCH=main

# From your GitHub App's settings page.
CIMISY_GITHUB_APP_ID=123456
CIMISY_GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
CIMISY_GITHUB_APP_CLIENT_SECRET=

# Paste the full contents of the .pem file GitHub gives you when you
# generate a private key. Either keep it as a real multi-line value (if
# your env loader preserves newlines in quotes) or replace newlines with
# literal \n — cimisy normalizes either form.
CIMISY_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Any long random string — used to sign the admin session cookie.
# Generate one with: openssl rand -base64 32
CIMISY_SESSION_SECRET=
